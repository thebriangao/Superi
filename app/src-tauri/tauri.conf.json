{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Superi",
  "version": "0.0.0",
  "identifier": "com.superi.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Superi",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
